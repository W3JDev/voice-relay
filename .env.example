# Voice Relay Configuration
# Copy to .env and fill in your values

# ═══ Voice Backend (VSaaS / Speaches) ═══
# Self-hosted STT/TTS via Speaches + VSaaS gateway
VSAAS_URL=https://speaches-production-15a8.up.railway.app
VSAAS_API_KEY=your-vsaas-client-key

# ═══ AI Agent Backend ═══
# Option A: OpenCLAW Gateway (recommended — full agent context + tools)
OPENCLAW_GATEWAY_URL=http://localhost:18789
OPENCLAW_GATEWAY_TOKEN=your-gateway-token

# Option B: Direct OpenAI
# OPENAI_API_KEY=sk-your-key

# Option C: Any OpenAI-compatible endpoint
# OPENCLAW_BACKEND_URL=https://your-endpoint/v1
# OPENCLAW_BACKEND_MODEL=your-model
# OPENCLAW_OPENAI_API_KEY=your-key

# ═══ Server Settings ═══
OPENCLAW_HOST=0.0.0.0
OPENCLAW_PORT=8765

# ═══ STT Settings ═══
# Local Whisper (used if VSAAS_URL not set)
OPENCLAW_STT_MODEL=base
OPENCLAW_STT_DEVICE=auto

# ═══ TTS Settings ═══
OPENCLAW_TTS_MODEL=kokoro
OPENCLAW_TTS_VOICE=af_heart
# Fine-tune voice selection (optional):
# KOKORO_VOICE=af_heart
# EDGE_TTS_VOICE=en-US-AriaNeural

# ═══ Session Settings ═══
VOICE_RELAY_SESSION_TTL=3600

# ═══ Auth ═══
OPENCLAW_REQUIRE_AUTH=false
# OPENCLAW_MASTER_KEY=your-master-key

# ═══ Phase 2: Database & Admin API ═══
# SQLite database path (default: ./voice_relay.db)
# In Docker, use /data/voice_relay.db with a mounted volume
# OPENCLAW_DB_PATH=/data/voice_relay.db

# Master key for the admin API (required for /admin/* endpoints)
# Generate a strong random key for production:
#   python3 -c "import secrets; print(secrets.token_urlsafe(32))"
# OPENCLAW_MASTER_KEY=change-me-in-production

# CORS origins for widget embedding (comma-separated, or "*" for all)
# Example: https://myapp.com,https://staging.myapp.com
# OPENCLAW_CORS_ORIGINS=*
